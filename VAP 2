Problem 2
Given a string s, composed of different combinations of '(' , ')', '{', '}', '[', ']'. Determine
whether the Expression is balanced or not.
An expression is balanced if:
1. Each opening bracket has a corresponding closing bracket of the same type.
2. Opening brackets must be closed in the correct order.
Concept: Stack
CODE :
#include <stdio.h>
#include <string.h>
char stack[1000000];
int top = -1;
void push(char c) {
stack[++top] = c;
}
char pop() {
if (top == -1)
return '#';
return stack[top--];
}
int isBalanced(char *s) {
top = -1;
for (int i = 0; s[i] != '\0'; i++) {
if (s[i] == '(' || s[i] == '{' || s[i] == '[')
push(s[i]);
else {
char ch = pop();
if ((s[i] == ')' && ch != '(') ||
(s[i] == '}' && ch != '{') ||
(s[i] == ']' && ch != '['))
return 0;
}
}
return (top == -1);
}
int main() {
char s[1000000];
printf("Aditya Nerkar\n");
printf("25070521198\n");
printf("Batch D1\n");
scanf("%s", s);
if (isBalanced(s))
printf("true");
else
printf("false");
return 0;
}
